pipeline {
  agent {
    docker {
      image 'abhishekf5/maven-abhishek-docker-agent:v1'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }
  environment {
    SONAR_URL = "https://sonarcloud.io"
    DOCKER_IMAGE = "jash1313/spring-boot-app:${BUILD_NUMBER}"
    GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
    GIT_USER_NAME = "jash1313"
  }
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }
    stage('Build and Test') {
      steps {
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
      }
    }
    stage('SonarCloud Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          sh 'echo Token length is $(echo $SONAR_TOKEN | wc -c)'
          sh '''
            cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
            mvn sonar:sonar \
              -Dsonar.projectKey=jash1313_Jenkins-Zero-To-Hero \
              -Dsonar.organization=jash1313 \
              -Dsonar.host.url=https://sonarcloud.io \
              -Dsonar.token=$SONAR_TOKEN
          '''
        }
      }
    }
    stage('Build Docker Image') {
      steps {
        sh 'docker build -t ${DOCKER_IMAGE} java-maven-sonar-argocd-helm-k8s/spring-boot-app'
      }
    }
    stage('Trivy Scan') {
      steps {
        sh 'trivy image --exit-code 1 --severity CRITICAL ${DOCKER_IMAGE} || true'
      }
    }
    stage('Push Docker Image') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
          sh '''
            echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
            docker push ${DOCKER_IMAGE}
          '''
        }
      }
    }
    stage('Update Helm Values') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'github-cred', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
          sh '''
            git config user.email "jenkins@cicd.com"
            git config user.name "Jenkins"
            sed -i "s/tag:.*/tag: ${BUILD_NUMBER}/" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/values.yaml
            git add .
            git commit -m "Update image tag to ${BUILD_NUMBER}"
            git push https://${GIT_USER}:${GIT_TOKEN}@github.com/jash1313/Jenkins-Zero-To-Hero HEAD:main
          '''
        }
      }
    }
  }
}
